APP_NAME="CI Ireland CS Platform"
APP_ENV=local                         # Change to: production
APP_KEY=                              # Run: php artisan key:generate
APP_DEBUG=true                        # Change to: false in production
APP_URL=http://localhost              # Change to: https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single                      # Change to: daily in production
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                       # Change to: warning in production

# ── Database ──────────────────────────────────────────────────────────────────
# Local (SQLite):
DB_CONNECTION=sqlite

# Production (MySQL) — uncomment and fill in:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=eduauto
# DB_USERNAME=eduauto_user
# DB_PASSWORD=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false                 # Change to: true in production
SESSION_EXPIRE_ON_CLOSE=false         # Change to: true in production
SESSION_PATH=/
SESSION_DOMAIN=null                   # Change to: yourdomain.com in production

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log                       # Change to: smtp in production
MAIL_SCHEME=null                      # Change to: tls in production
MAIL_HOST=127.0.0.1                   # Change to: your SMTP host
MAIL_PORT=2525                        # Change to: 587 for TLS
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost    # Change to: yourdomain.com in production
SANCTUM_EXPIRATION=20160              # Token lifetime in minutes (14 days)

# ── Webhook ───────────────────────────────────────────────────────────────────
# Generate with: php artisan tinker --execute="echo bin2hex(random_bytes(32));"
WEBHOOK_SECRET=

VITE_APP_NAME="${APP_NAME}"


  Steps on the VPS after uploading this file:

  # 1. Generate a fresh APP_KEY
  php artisan key:generate

  # 2. Generate a fresh WEBHOOK_SECRET and paste it in
  php artisan tinker --execute="echo bin2hex(random_bytes(32));"

  # 3. Clear config cache so new values are picked up
  php artisan config:clear
  php artisan config:cache

  # 4. Run migrations
  php artisan migrate --force